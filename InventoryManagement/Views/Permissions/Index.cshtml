@model Application.Interfaces.Models.AllPermissionsViewModel
@{
    ViewData["Title"] = "إدارة الصلاحيات";
}

<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700&display=swap" rel="stylesheet" />
<link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet" />
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

<script>
    tailwind.config = {
        darkMode: "class",
        theme: {
            extend: {
                colors: {
                    primary: "#0ea5e9",
                    secondary: "#64748b",
                    accent: "#f59e0b",
                    "background-light": "#f8fafc",
                    "background-dark": "#0f172a",
                    "surface-light": "#ffffff",
                    "surface-dark": "#1e293b",
                    "border-light": "#e2e8f0",
                    "border-dark": "#334155",
                },
                fontFamily: {
                    sans: ["Cairo", "sans-serif"],
                    display: ["Cairo", "sans-serif"],
                },
            },
        },
    };
</script>

<div class="bg-background-light dark:bg-background-dark text-slate-800 dark:text-slate-200 font-sans min-h-screen flex flex-col transition-colors duration-300">
    <main class="flex-1 mx-auto w-full flex flex-col gap-6 p-6">
        
        @* Header Section *@
        <section class="bg-surface-light dark:bg-surface-dark p-6 rounded-xl border border-border-light dark:border-border-dark shadow-sm">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                <div>
                    <h2 class="text-2xl font-bold mb-2 flex items-center gap-2 text-slate-900 dark:text-white">
                        <span class="material-icons-round text-accent">security</span>
                        إدارة الصلاحيات
                    </h2>
                    <p class="text-sm text-slate-500 dark:text-slate-400">تحديد صلاحيات الوصول للصفحات والوظائف لكل دور</p>
                </div>
                <div class="flex gap-3">
                    <form asp-action="SeedRolePermissions" method="post" class="inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg transition-colors shadow-sm">
                            <span class="material-icons-round text-lg">add_circle</span>
                            <span class="font-medium">إضافة صلاحيات Admin</span>
                        </button>
                    </form>
                    <a href="@Url.Action("Index", "UserManagement")" class="inline-flex items-center gap-2 px-4 py-2 bg-secondary hover:bg-secondary/90 text-white rounded-lg transition-colors shadow-sm">
                        <span class="material-icons-round text-lg">arrow_back</span>
                        <span class="font-medium">رجوع</span>
                    </a>
                </div>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="mt-4 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg flex items-center gap-3">
                    <span class="material-icons-round text-green-600 dark:text-green-400">check_circle</span>
                    <span class="text-green-800 dark:text-green-200">@TempData["Success"]</span>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="mt-4 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg flex items-center gap-3">
                    <span class="material-icons-round text-red-600 dark:text-red-400">error</span>
                    <span class="text-red-800 dark:text-red-200">@TempData["Error"]</span>
                </div>
            }

            @if (TempData["Info"] != null)
            {
                <div class="mt-4 p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg flex items-center gap-3">
                    <span class="material-icons-round text-blue-600 dark:text-blue-400">info</span>
                    <span class="text-blue-800 dark:text-blue-200">@TempData["Info"]</span>
                </div>
            }
        </section>

        @* Roles Cards Section *@
        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @if (Model.Roles != null && Model.Roles.Any())
            {
                @foreach (var role in Model.Roles)
                {
                    <div class="bg-surface-light dark:bg-surface-dark rounded-xl border border-border-light dark:border-border-dark shadow-sm hover:shadow-md transition-shadow overflow-hidden">
                        <div class="bg-gradient-to-r from-primary to-accent p-4">
                            <div class="flex items-center gap-3">
                                <div class="bg-white/20 rounded-full p-3">
                                    <span class="material-icons-round text-white text-2xl">shield</span>
                                </div>
                                <div class="flex-1">
                                    <h3 class="text-lg font-bold text-white">@role.RoleName</h3>
                                    <p class="text-xs text-white/80">المستوى @role.Level</p>
                                </div>
                            </div>
                        </div>
                        
                        <div class="p-6">
                            <div class="flex items-center justify-between mb-4">
                                <div class="flex items-center gap-2">
                                    <span class="material-icons-round text-slate-400">verified_user</span>
                                    <span class="text-sm text-slate-600 dark:text-slate-400">الصلاحيات المفعلة</span>
                                </div>
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-200">
                                    @role.PermissionCount
                                </span>
                            </div>

                            <a href="@Url.Action("ManageRole", new { id = role.RoleId })" 
                               class="w-full inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-gradient-to-r from-primary to-accent hover:from-primary/90 hover:to-accent/90 text-white rounded-lg transition-all font-medium shadow-sm">
                                <span class="material-icons-round text-lg">settings</span>
                                <span>إدارة الصلاحيات</span>
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-span-full bg-surface-light dark:bg-surface-dark rounded-xl border border-border-light dark:border-border-dark p-12 text-center">
                    <span class="material-icons-round text-6xl text-slate-300 dark:text-slate-600">folder_off</span>
                    <p class="mt-4 text-slate-500 dark:text-slate-400">لا توجد أدوار متاحة</p>
                </div>
            }
        </section>

        @* Available Permissions Overview *@
        @if (Model.PermissionGroups != null && Model.PermissionGroups.Any())
        {
            <section class="bg-surface-light dark:bg-surface-dark rounded-xl border border-border-light dark:border-border-dark shadow-sm overflow-hidden">
                <div class="p-6 border-b border-border-light dark:border-border-dark">
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white flex items-center gap-2">
                        <span class="material-icons-round text-accent">list</span>
                        الصلاحيات المتاحة في النظام
                    </h3>
                </div>
                
                <div class="p-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        @foreach (var group in Model.PermissionGroups)
                        {
                            <div class="bg-slate-50 dark:bg-slate-800/30 rounded-lg p-4 border border-border-light dark:border-border-dark">
                                <h4 class="font-semibold text-slate-900 dark:text-white mb-3 flex items-center gap-2">
                                    <span class="material-icons-round text-primary text-lg">folder</span>
                                    @group.ModuleName
                                </h4>
                                <ul class="space-y-2">
                                    @foreach (var permission in group.Permissions)
                                    {
                                        <li class="flex items-start gap-2 text-sm">
                                            <span class="material-icons-round text-slate-400 text-sm mt-0.5">check_circle_outline</span>
                                            <div class="flex-1">
                                                <div class="text-slate-700 dark:text-slate-300 font-medium">@permission.Name</div>
                                                <div class="text-xs text-slate-500 dark:text-slate-400">@permission.Code</div>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                    </div>
                </div>
            </section>
        }

        @* Statistics Section *@
        @if (Model.Roles != null && Model.Roles.Any())
        {
            var totalPermissions = Model.PermissionGroups?.Sum(g => g.Permissions.Count) ?? 0;
            var totalAssignedPermissions = Model.Roles.Sum(r => r.PermissionCount);
            
            <section class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl p-6 text-white shadow-lg">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-blue-100 text-sm font-medium">إجمالي الأدوار</p>
                            <h3 class="text-3xl font-bold mt-2">@Model.Roles.Count</h3>
                        </div>
                        <div class="bg-white/20 rounded-full p-3">
                            <span class="material-icons-round text-4xl">shield</span>
                        </div>
                    </div>
                </div>

                <div class="bg-gradient-to-br from-green-500 to-green-600 rounded-xl p-6 text-white shadow-lg">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-green-100 text-sm font-medium">الصلاحيات المتاحة</p>
                            <h3 class="text-3xl font-bold mt-2">@totalPermissions</h3>
                        </div>
                        <div class="bg-white/20 rounded-full p-3">
                            <span class="material-icons-round text-4xl">list</span>
                        </div>
                    </div>
                </div>

                <div class="bg-gradient-to-br from-amber-500 to-amber-600 rounded-xl p-6 text-white shadow-lg">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-amber-100 text-sm font-medium">الصلاحيات المفعلة</p>
                            <h3 class="text-3xl font-bold mt-2">@totalAssignedPermissions</h3>
                        </div>
                        <div class="bg-white/20 rounded-full p-3">
                            <span class="material-icons-round text-4xl">verified_user</span>
                        </div>
                    </div>
                </div>
            </section>
        }
    </main>
</div>
