@{
    ViewData["Title"] = "Access Denied";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EGX Inventory Management</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gradient-to-br from-red-50 to-orange-100 min-h-screen">
    <div class="flex items-center justify-center min-h-screen p-4">
        <div class="w-full max-w-md">
            <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
                <!-- Header -->
                <div class="bg-gradient-to-r from-red-600 to-orange-600 px-8 py-6 text-center">
                    <div class="flex justify-center mb-4">
                        <div class="bg-white/20 backdrop-blur-sm rounded-full p-3">
                            <span class="material-icons-round text-white text-3xl">block</span>
                        </div>
                    </div>
                    <h1 class="text-2xl font-bold text-white">Access Denied</h1>
                    <p class="text-red-100 text-sm mt-1">You don't have permission to access this resource</p>
                </div>

                <!-- Content -->
                <div class="px-8 py-6 text-center">
                    <div class="mb-6">
                        <div class="inline-flex items-center justify-center w-16 h-16 bg-red-100 rounded-full mb-4">
                            <span class="material-icons-round text-red-600 text-2xl">lock</span>
                        </div>
                        <h2 class="text-xl font-semibold text-gray-900 mb-2">Access Restricted</h2>
                        <p class="text-gray-600 mb-6">
                            Sorry, you don't have sufficient permissions to access this page. 
                            Please contact your administrator if you believe this is an error.
                        </p>
                    </div>

                    <div class="space-y-3">
                        <a href="@Url.Action("Index", "Home")" 
                           class="w-full inline-flex items-center justify-center px-4 py-2.5 bg-gradient-to-r from-red-600 to-orange-600 text-white rounded-lg font-medium hover:from-red-700 hover:to-orange-700 transition-all transform hover:scale-[1.02] shadow-lg">
                            <span class="material-icons-round text-lg mr-2">home</span>
                            Back to Dashboard
                        </a>
                        
                        <a href="javascript:history.back()" 
                           class="w-full inline-flex items-center justify-center px-4 py-2.5 border border-gray-300 text-gray-700 rounded-lg font-medium hover:bg-gray-50 transition-colors">
                            <span class="material-icons-round text-lg mr-2">arrow_back</span>
                            Go Back
                        </a>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="mt-6 pt-6 border-t border-gray-200">
                            <form asp-action="Logout" asp-controller="Account" method="post" class="inline">
                                <button type="submit" class="text-sm text-gray-500 hover:text-gray-700 underline">
                                    Sign out as different user
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>

            <!-- Footer -->
            <div class="text-center mt-6">
                <p class="text-gray-500 text-xs">
                    © 2024 EGX Inventory Management System. All rights reserved.
                </p>
            </div>
        </div>
    </div>
</body>
</html>
