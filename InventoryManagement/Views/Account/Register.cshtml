@model InventoryManagement.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EGX Inventory Management</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gradient-to-br from-green-50 to-emerald-100 min-h-screen">
    <div class="flex items-center justify-center min-h-screen p-4">
        <div class="w-full max-w-2xl">
            <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
                <!-- Header -->
                <div class="bg-gradient-to-r from-green-600 to-emerald-600 px-8 py-6 text-center">
                    <div class="flex justify-center mb-4">
                        <div class="bg-white/20 backdrop-blur-sm rounded-full p-3">
                            <span class="material-icons-round text-white text-3xl">person_add</span>
                        </div>
                    </div>
                    <h1 class="text-2xl font-bold text-white">Create Account</h1>
                    <p class="text-green-100 text-sm mt-1">Join EGX Inventory Management System</p>
                </div>

                <!-- Form -->
                <div class="px-8 py-6">
                    <form asp-action="Register" asp-controller="Account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>
                        
                        <input type="hidden" asp-for="ReturnUrl" />

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label asp-for="FirstName" class="block text-sm font-medium text-gray-700 mb-1">
                                    <span class="material-icons-round text-lg align-middle mr-1">person</span>
                                    First Name
                                </label>
                                <input asp-for="FirstName" type="text" 
                                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                                       placeholder="First name" />
                                <span asp-validation-for="FirstName" class="text-red-500 text-xs"></span>
                            </div>

                            <div>
                                <label asp-for="LastName" class="block text-sm font-medium text-gray-700 mb-1">
                                    <span class="material-icons-round text-lg align-middle mr-1">person</span>
                                    Last Name
                                </label>
                                <input asp-for="LastName" type="text" 
                                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                                       placeholder="Last name" />
                                <span asp-validation-for="LastName" class="text-red-500 text-xs"></span>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                            <div>
                                <label asp-for="Username" class="block text-sm font-medium text-gray-700 mb-1">
                                    <span class="material-icons-round text-lg align-middle mr-1">badge</span>
                                    Username
                                </label>
                                <input asp-for="Username" type="text" 
                                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                                       placeholder="Choose username" />
                                <span asp-validation-for="Username" class="text-red-500 text-xs"></span>
                            </div>

                            <div>
                                <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1">
                                    <span class="material-icons-round text-lg align-middle mr-1">email</span>
                                    Email
                                </label>
                                <input asp-for="Email" type="email" 
                                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                                       placeholder="email@example.com" />
                                <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                            <div>
                                <label asp-for="Password" class="block text-sm font-medium text-gray-700 mb-1">
                                    <span class="material-icons-round text-lg align-middle mr-1">lock</span>
                                    Password
                                </label>
                                <input asp-for="Password" type="password" 
                                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                                       placeholder="Create password" />
                                <span asp-validation-for="Password" class="text-red-500 text-xs"></span>
                            </div>

                            <div>
                                <label asp-for="ConfirmPassword" class="block text-sm font-medium text-gray-700 mb-1">
                                    <span class="material-icons-round text-lg align-middle mr-1">lock</span>
                                    Confirm Password
                                </label>
                                <input asp-for="ConfirmPassword" type="password" 
                                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                                       placeholder="Confirm password" />
                                <span asp-validation-for="ConfirmPassword" class="text-red-500 text-xs"></span>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                            <div>
                                <label asp-for="EmployeeCode" class="block text-sm font-medium text-gray-700 mb-1">
                                    <span class="material-icons-round text-lg align-middle mr-1">badge</span>
                                    Employee Code
                                </label>
                                <input asp-for="EmployeeCode" type="number" 
                                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                                       placeholder="Employee code (optional)" />
                                <span asp-validation-for="EmployeeCode" class="text-red-500 text-xs"></span>
                            </div>

                            <div>
                                <label asp-for="Department" class="block text-sm font-medium text-gray-700 mb-1">
                                    <span class="material-icons-round text-lg align-middle mr-1">business</span>
                                    Department
                                </label>
                                <input asp-for="Department" type="text" 
                                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                                       placeholder="Department (optional)" />
                                <span asp-validation-for="Department" class="text-red-500 text-xs"></span>
                            </div>
                        </div>

                        <div class="mt-6">
                            <button type="submit" 
                                    class="w-full bg-gradient-to-r from-green-600 to-emerald-600 text-white py-2.5 rounded-lg font-medium hover:from-green-700 hover:to-emerald-700 transition-all transform hover:scale-[1.02] shadow-lg">
                                <span class="material-icons-round text-lg align-middle mr-2">how_to_reg</span>
                                Create Account
                            </button>
                        </div>
                    </form>

                    <div class="mt-6 text-center">
                        <p class="text-sm text-gray-600">
                            Already have an account? 
                            <a asp-action="Login" asp-controller="Account" class="text-green-600 hover:text-green-500 font-medium">
                                Sign in
                            </a>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="text-center mt-6">
                <p class="text-gray-500 text-xs">
                    © 2024 EGX Inventory Management System. All rights reserved.
                </p>
            </div>
        </div>
    </div>

    <script>
        // Add form validation styling
        document.addEventListener('DOMContentLoaded', function() {
            const inputs = document.querySelectorAll('input[type="text"], input[type="password"], input[type="email"], input[type="number"]');
            inputs.forEach(input => {
                input.addEventListener('focus', function() {
                    this.parentElement.classList.add('transform', 'scale-[1.02]');
                });
                input.addEventListener('blur', function() {
                    this.parentElement.classList.remove('transform', 'scale-[1.02]');
                });
            });
        });
    </script>
</body>
</html>
