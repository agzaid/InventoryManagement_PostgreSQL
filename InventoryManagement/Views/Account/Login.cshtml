@model InventoryManagement.Controllers.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EGX Inventory Management</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gradient-to-br from-blue-50 to-indigo-100 min-h-screen">
    <div class="flex items-center justify-center min-h-screen p-4">
        <div class="w-full max-w-md">
            <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
                <!-- Header -->
                <div class="bg-gradient-to-r from-blue-600 to-indigo-600 px-8 py-6 text-center">
                    <div class="flex justify-center mb-4">
                        <div class="bg-white/20 backdrop-blur-sm rounded-full p-3">
                            <span class="material-icons-round text-white text-3xl">inventory_2</span>
                        </div>
                    </div>
                    <h1 class="text-2xl font-bold text-white">EGX Inventory</h1>
                    <p class="text-blue-100 text-sm mt-1">Sign in to your account</p>
                </div>

                <!-- Form -->
                <div class="px-8 py-6">
                    <form asp-action="Login" asp-controller="Account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>
                        
                        <input type="hidden" asp-for="ReturnUrl" />

                        <div class="space-y-4">
                            <div>
                                <label asp-for="Username" class="block text-sm font-medium text-gray-700 mb-1">
                                    <span class="material-icons-round text-lg align-middle mr-1">person</span>
                                    Username
                                </label>
                                <input asp-for="Username" type="text" 
                                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                                       placeholder="Enter your username" />
                                <span asp-validation-for="Username" class="text-red-500 text-xs"></span>
                            </div>

                            <div>
                                <label asp-for="Password" class="block text-sm font-medium text-gray-700 mb-1">
                                    <span class="material-icons-round text-lg align-middle mr-1">lock</span>
                                    Password
                                </label>
                                <div class="relative">
                                    <input asp-for="Password" type="password" id="passwordInput"
                                           class="w-full px-4 py-2 pr-12 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                                           placeholder="Enter your password" />
                                    <button type="button" id="togglePassword" 
                                            class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-500 hover:text-gray-700 focus:outline-none">
                                        <span id="eyeIcon" class="material-icons-round text-lg">visibility</span>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="text-red-500 text-xs"></span>
                            </div>

                            <div class="flex items-center justify-between">
                                <label class="flex items-center">
                                    <input asp-for="RememberMe" type="checkbox" class="rounded text-blue-600 focus:ring-blue-500 mr-2" />
                                    <span class="text-sm text-gray-600">Remember me</span>
                                </label>
                                <a href="#" class="text-sm text-blue-600 hover:text-blue-500">Forgot password?</a>
                            </div>
                        </div>

                        <div class="mt-6">
                            <button type="submit" 
                                    class="w-full bg-gradient-to-r from-blue-600 to-indigo-600 text-white py-2.5 rounded-lg font-medium hover:from-blue-700 hover:to-indigo-700 transition-all transform hover:scale-[1.02] shadow-lg">
                                <span class="material-icons-round text-lg align-middle mr-2">login</span>
                                Sign In
                            </button>
                        </div>
                    </form>

                    <div class="mt-6 text-center">
                        <p class="text-sm text-gray-600">
                            Don't have an account? 
                            <a asp-action="Register" asp-controller="Account" class="text-blue-600 hover:text-blue-500 font-medium">
                                Sign up
                            </a>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="text-center mt-6">
                <p class="text-gray-500 text-xs">
                    © 2024 EGX Inventory Management System. All rights reserved.
                </p>
            </div>
        </div>
    </div>

    <script>
        // Add form validation styling
        document.addEventListener('DOMContentLoaded', function() {
            const inputs = document.querySelectorAll('input[type="text"], input[type="password"], input[type="email"]');
            inputs.forEach(input => {
                input.addEventListener('focus', function() {
                    this.parentElement.classList.add('transform', 'scale-[1.02]');
                });
                input.addEventListener('blur', function() {
                    this.parentElement.classList.remove('transform', 'scale-[1.02]');
                });
            });

            // Password visibility toggle
            const togglePassword = document.getElementById('togglePassword');
            const passwordInput = document.getElementById('passwordInput');
            const eyeIcon = document.getElementById('eyeIcon');

            togglePassword.addEventListener('click', function() {
                const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                passwordInput.setAttribute('type', type);
                
                // Toggle the eye icon
                if (type === 'password') {
                    eyeIcon.textContent = 'visibility';
                } else {
                    eyeIcon.textContent = 'visibility_off';
                }
            });
        });
    </script>
</body>
</html>
