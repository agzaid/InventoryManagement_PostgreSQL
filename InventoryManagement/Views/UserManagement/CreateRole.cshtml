@model InventoryManagement.Models.UserManagement.CreateRoleViewModel
@{
    ViewData["Title"] = "إنشاء دور جديد";
}

<div class="container-fluid" dir="rtl">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-plus"></i> إنشاء دور جديد
                    </h5>
                </div>
                <div class="card-body">
                    <form asp-action="CreateRole" method="post">
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Name" class="form-label"></label>
                                    <input asp-for="Name" class="form-control" />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Level" class="form-label"></label>
                                    <input asp-for="Level" type="number" class="form-control" min="0" max="100" />
                                    <span asp-validation-for="Level" class="text-danger"></span>
                                    <small class="text-muted">رقم أعلى يعني صلاحيات أكبر</small>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input asp-for="IsSystemRole" class="form-check-input" />
                                <label asp-for="IsSystemRole" class="form-check-label"></label>
                            </div>
                            <small class="text-muted">الأدوار النظامية لا يمكن تعديلها أو حذفها</small>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="@Url.Action("Roles")" class="btn btn-secondary">
                                <i class="fas fa-arrow-right"></i> رجوع
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> حفظ
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
