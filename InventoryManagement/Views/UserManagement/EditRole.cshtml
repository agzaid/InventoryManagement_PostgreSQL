@model InventoryManagement.Models.UserManagement.EditRoleViewModel
@{
    ViewData["Title"] = "تعديل الدور";
}

<div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100 p-6">
    <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-3xl shadow-xl border border-slate-100 overflow-hidden">
            <div class="bg-gradient-to-r from-blue-500 to-indigo-500 p-6">
                <div class="flex items-center justify-between">
                    <h2 class="text-2xl font-bold text-white flex items-center gap-3">
                        <span class="material-icons-round text-3xl">edit</span>
                        تعديل الدور: @Model.Name
                    </h2>
                    <a href="@Url.Action("ManageRoles", "UserManagement")" class="text-white hover:bg-white/20 rounded-full p-2 transition-colors">
                        <span class="material-icons-round">close</span>
                    </a>
                </div>
            </div>

            <form asp-action="EditRole" method="post" class="p-8">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="IsSystemRole" />

                <div asp-validation-summary="ModelOnly" class="mb-6 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl"></div>

                <div class="space-y-6">
                    <div>
                        <label asp-for="Name" class="block text-sm font-semibold text-slate-700 mb-2">
                            اسم الدور <span class="text-red-500">*</span>
                        </label>
                        <input asp-for="Name" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" />
                        <span asp-validation-for="Name" class="text-red-500 text-sm mt-1"></span>
                    </div>

                    <div>
                        <label asp-for="Level" class="block text-sm font-semibold text-slate-700 mb-2">
                            المستوى
                        </label>
                        <input asp-for="Level" type="number" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all" />
                        <span asp-validation-for="Level" class="text-red-500 text-sm mt-1"></span>
                    </div>

                    <div>
                        <label asp-for="Description" class="block text-sm font-semibold text-slate-700 mb-2">
                            الوصف
                        </label>
                        <textarea asp-for="Description" rows="3" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"></textarea>
                        <span asp-validation-for="Description" class="text-red-500 text-sm mt-1"></span>
                    </div>

                    <div class="border-t border-slate-200 pt-6">
                        <h4 class="font-semibold text-slate-800 mb-4 flex items-center gap-2">
                            <span class="material-icons-round text-purple-600">security</span>
                            صلاحيات الدور
                        </h4>
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-h-96 overflow-y-auto">
                            @{
                                var permissionsGrouped = ViewBag.PermissionsGrouped as IEnumerable<dynamic>;
                                var moduleStyles = new Dictionary<string, (string bgClass, string textClass, string checkboxClass, string icon)>
                                {
                                    { "الحركة اليومية", ("bg-yellow-50", "text-yellow-800", "text-yellow-600", "calendar_today") },
                                    { "إدارة المخزون", ("bg-blue-50", "text-blue-800", "text-blue-600", "inventory_2") },
                                    { "أكواد النظام", ("bg-purple-50", "text-purple-800", "text-purple-600", "grid_view") },
                                    { "إدارة النظام", ("bg-red-50", "text-red-800", "text-red-600", "settings") }
                                };
                                var defaultStyles = new[]
                                {
                                    ("bg-yellow-50", "text-yellow-800", "text-yellow-600", "folder"),
                                    ("bg-blue-50", "text-blue-800", "text-blue-600", "folder"),
                                    ("bg-purple-50", "text-purple-800", "text-purple-600", "folder"),
                                    ("bg-red-50", "text-red-800", "text-red-600", "folder")
                                };
                                int styleIndex = 0;
                            }

                            @if (permissionsGrouped != null)
                            {
                                @foreach (var group in permissionsGrouped)
                                {
                                    var moduleName = group.Module as string;
                                    var permissions = group.Permissions as IEnumerable<dynamic>;
                                    
                                    var style = moduleStyles.ContainsKey(moduleName)
                                        ? moduleStyles[moduleName]
                                        : defaultStyles[styleIndex % defaultStyles.Length];

                                    <div class="@style.Item1 rounded-xl p-4">
                                        <h5 class="font-bold @style.Item2 mb-3 flex items-center gap-2">
                                            <span class="material-icons-round text-sm">@style.Item4</span>
                                            @moduleName
                                        </h5>
                                        <div class="space-y-2">
                                            @if (permissions != null)
                                            {
                                                @foreach (var permission in permissions)
                                                {
                                                    var permCode = permission.PermissionCode as string;
                                                    var permName = permission.PermissionName as string;
                                                    var isChecked = Model.SelectedPermissions.Contains(permCode);

                                                    <label class="flex items-center gap-2 cursor-pointer">
                                                        <input type="checkbox" name="selectedPermissions" value="@permCode" @(isChecked ? "checked" : "") class="w-4 h-4 rounded border-slate-300 @style.Item3">
                                                        <span class="text-sm text-slate-700">@permName</span>
                                                    </label>
                                                }
                                            }
                                        </div>
                                    </div>

                                    styleIndex++;
                                }
                            }
                            else
                            {
                                <div class="col-span-full text-center text-slate-400 py-8">
                                    <p>لا توجد صلاحيات متاحة</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="flex items-center justify-end gap-3 mt-8 pt-6 border-t border-slate-100">
                    <a href="@Url.Action("ManageRoles", "UserManagement")" class="px-6 py-3 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-xl transition-colors font-medium">
                        <span class="material-icons-round text-sm align-middle">close</span>
                        إلغاء
                    </a>
                    <button type="submit" class="px-6 py-3 bg-gradient-to-r from-blue-500 to-indigo-500 hover:from-blue-600 hover:to-indigo-600 text-white rounded-xl transition-all font-medium shadow-lg">
                        <span class="material-icons-round text-sm align-middle">save</span>
                        حفظ التغييرات
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
