@model InventoryManagement.Models.UserManagement.AssignRolesViewModel
@{
    ViewData["Title"] = "تعيين الأدوار للمستخدمين";
}

<div class="container-fluid" dir="rtl">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-user-tag"></i> تعيين الأدوار للمستخدمين
                    </h5>
                </div>
                <div class="card-body">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="AssignRoles" method="post">
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead class="table-dark">
                                    <tr>
                                        <th>المستخدم</th>
                                        <th>الاسم الكامل</th>
                                        <th>الكود الوظيفي</th>
                                        <th>الدور المخصص</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.Users.Count; i++)
                                    {
                                        var user = Model.Users[i];
                                        var currentUserRole = Model.UserRoles.FirstOrDefault(ur => ur.UserId == user.Id);
                                        
                                        <tr>
                                            <td>@user.UserName</td>
                                            <td>@user.FullName</td>
                                            <td>@user.EmployeeCode</td>
                                            <td>
                                                <input type="hidden" name="UserRoles[@i].UserId" value="@user.Id" />
                                                <select name="UserRoles[@i].RoleId" class="form-select">
                                                    <option value="">-- لا يوجد دور --</option>
                                                    @foreach (var role in Model.Roles)
                                                    {
                                                        var isSelected = currentUserRole?.RoleId == role.Id;
                                                        <option value="@role.Id" selected="@isSelected">
                                                            @role.Name - @role.Description
                                                        </option>
                                                    }
                                                </select>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="fas fa-arrow-right"></i> رجوع
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> حفظ التخصيصات
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
