@model InventoryManagement.Models.UserManagement.AssignRolesViewModel
@{
    ViewData["Title"] = "تعيين الأدوار للمستخدمين";
}

<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700&display=swap" rel="stylesheet" />
<link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet" />
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

<script>
    tailwind.config = {
        darkMode: "class",
        theme: {
            extend: {
                colors: {
                    primary: "#0ea5e9",
                    secondary: "#64748b",
                    accent: "#f59e0b",
                    "background-light": "#f8fafc",
                    "background-dark": "#0f172a",
                    "surface-light": "#ffffff",
                    "surface-dark": "#1e293b",
                    "border-light": "#e2e8f0",
                    "border-dark": "#334155",
                },
                fontFamily: {
                    sans: ["Cairo", "sans-serif"],
                    display: ["Cairo", "sans-serif"],
                },
            },
        },
    };
</script>

<style type="text/tailwindcss">
    @@layer utilities {
        .scrollbar-hide::-webkit-scrollbar {
            display: none;
        }

        .scrollbar-hide {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    }
</style>

<div class="bg-background-light dark:bg-background-dark text-slate-800 dark:text-slate-200 font-sans min-h-screen flex flex-col transition-colors duration-300">
    <main class="flex-1 mx-auto w-full flex flex-col gap-6 p-6">
        
        @* Header Section *@
        <section class="bg-surface-light dark:bg-surface-dark p-6 rounded-xl border border-border-light dark:border-border-dark shadow-sm">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                <div>
                    <h2 class="text-2xl font-bold mb-2 flex items-center gap-2 text-slate-900 dark:text-white">
                        <span class="material-icons-round text-accent">assignment_ind</span>
                        تعيين الأدوار للمستخدمين
                    </h2>
                    <p class="text-sm text-slate-500 dark:text-slate-400">قم بتخصيص الأدوار والصلاحيات لكل مستخدم في النظام</p>
                </div>
                <div class="flex gap-3">
                    <a href="@Url.Action("Index")" class="inline-flex items-center gap-2 px-4 py-2 bg-secondary hover:bg-secondary/90 text-white rounded-lg transition-colors shadow-sm">
                        <span class="material-icons-round text-lg">arrow_back</span>
                        <span class="font-medium">رجوع</span>
                    </a>
                </div>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="mt-4 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg flex items-center gap-3">
                    <span class="material-icons-round text-green-600 dark:text-green-400">check_circle</span>
                    <span class="text-green-800 dark:text-green-200">@TempData["Success"]</span>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="mt-4 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg flex items-center gap-3">
                    <span class="material-icons-round text-red-600 dark:text-red-400">error</span>
                    <span class="text-red-800 dark:text-red-200">@TempData["Error"]</span>
                </div>
            }
        </section>

        @* Users Table Section *@
        <section class="bg-surface-light dark:bg-surface-dark rounded-xl border border-border-light dark:border-border-dark shadow-sm overflow-hidden">
            <form id="assignRolesForm" asp-action="AssignRoles" method="post">
                @Html.AntiForgeryToken()
                
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="bg-slate-50 dark:bg-slate-800/50 border-b border-border-light dark:border-border-dark">
                            <tr>
                                <th class="px-6 py-4 text-right text-xs font-semibold text-slate-700 dark:text-slate-300 uppercase tracking-wider w-16">#</th>
                                <th class="px-6 py-4 text-right text-xs font-semibold text-slate-700 dark:text-slate-300 uppercase tracking-wider">المستخدم</th>
                                <th class="px-6 py-4 text-right text-xs font-semibold text-slate-700 dark:text-slate-300 uppercase tracking-wider">الاسم الكامل</th>
                                <th class="px-6 py-4 text-right text-xs font-semibold text-slate-700 dark:text-slate-300 uppercase tracking-wider">الكود الوظيفي</th>
                                <th class="px-6 py-4 text-right text-xs font-semibold text-slate-700 dark:text-slate-300 uppercase tracking-wider">الدور المخصص</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border-light dark:divide-border-dark">
                            @if (Model.Users != null && Model.Users.Any())
                            {
                                @for (int i = 0; i < Model.Users.Count; i++)
                                {
                                    var user = Model.Users[i];
                                    var currentUserRole = Model.UserRoles?.FirstOrDefault(ur => ur.UserId == user.Id);
                                    
                                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-900 dark:text-slate-100">@(i + 1)</td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <div class="flex items-center gap-3">
                                                <div class="flex-shrink-0 h-10 w-10 rounded-full bg-gradient-to-br from-primary to-accent flex items-center justify-center">
                                                    <span class="text-white font-semibold text-sm">
                                                        @(user.UserName?.Substring(0, 1).ToUpper() ?? "U")
                                                    </span>
                                                </div>
                                                <div>
                                                    <div class="text-sm font-semibold text-slate-900 dark:text-white">@user.UserName</div>
                                                    <div class="text-xs text-slate-500 dark:text-slate-400">@user.Id</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 text-sm text-slate-700 dark:text-slate-300">
                                            @(user.FullName ?? "-")
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            @if (!string.IsNullOrEmpty(user.EmployeeCode))
                                            {
                                                <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-200">
                                                    <span class="material-icons-round text-xs">badge</span>
                                                    @user.EmployeeCode
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-slate-400 dark:text-slate-500 text-sm">-</span>
                                            }
                                        </td>
                                        <td class="px-6 py-4">
                                            <input type="hidden" name="UserRoles[@i].UserId" value="@user.Id" />
                                            <div class="relative">
                                                <select name="UserRoles[@i].RoleId" 
                                                        class="w-full px-4 py-2.5 bg-white dark:bg-slate-800 border border-border-light dark:border-border-dark rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-all text-slate-900 dark:text-white appearance-none cursor-pointer">
                                                    <option value="">-- لا يوجد دور --</option>
                                                    @if (Model.Roles != null)
                                                    {
                                                        @foreach (var role in Model.Roles)
                                                        {
                                                            var isSelected = currentUserRole?.RoleId == role.Id;
                                                            <option value="@role.Id" selected="@isSelected">
                                                                @role.Name @(!string.IsNullOrEmpty(role.Description) ? $"- {role.Description}" : "")
                                                            </option>
                                                        }
                                                    }
                                                </select>
                                                <span class="material-icons-round absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">expand_more</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="px-6 py-12 text-center">
                                        <div class="flex flex-col items-center gap-3">
                                            <span class="material-icons-round text-6xl text-slate-300 dark:text-slate-600">person_off</span>
                                            <p class="text-slate-500 dark:text-slate-400">لا توجد مستخدمين متاحين</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.Users != null && Model.Users.Any())
                {
                    <div class="p-6 bg-slate-50 dark:bg-slate-800/30 border-t border-border-light dark:border-border-dark flex items-center justify-between">
                        <div class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400">
                            <span class="material-icons-round text-lg">info</span>
                            <span>إجمالي المستخدمين: <strong class="text-slate-900 dark:text-white">@Model.Users.Count</strong></span>
                        </div>
                        <button type="submit" id="saveBtn" 
                                class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-primary to-accent hover:from-primary/90 hover:to-accent/90 text-white rounded-lg transition-all font-semibold shadow-lg hover:shadow-xl">
                            <span class="material-icons-round text-lg">save</span>
                            <span>حفظ التخصيصات</span>
                        </button>
                    </div>
                }
            </form>
        </section>

        @* Statistics Section *@
        @if (Model.Users != null && Model.Users.Any())
        {
            var usersWithRoles = Model.UserRoles?.Count() ?? 0;
            var usersWithoutRoles = Model.Users.Count - usersWithRoles;
            
            <section class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl p-6 text-white shadow-lg">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-blue-100 text-sm font-medium">إجمالي المستخدمين</p>
                            <h3 class="text-3xl font-bold mt-2">@Model.Users.Count</h3>
                        </div>
                        <div class="bg-white/20 rounded-full p-3">
                            <span class="material-icons-round text-4xl">group</span>
                        </div>
                    </div>
                </div>

                <div class="bg-gradient-to-br from-green-500 to-green-600 rounded-xl p-6 text-white shadow-lg">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-green-100 text-sm font-medium">لديهم أدوار</p>
                            <h3 class="text-3xl font-bold mt-2">@usersWithRoles</h3>
                        </div>
                        <div class="bg-white/20 rounded-full p-3">
                            <span class="material-icons-round text-4xl">verified_user</span>
                        </div>
                    </div>
                </div>

                <div class="bg-gradient-to-br from-amber-500 to-amber-600 rounded-xl p-6 text-white shadow-lg">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-amber-100 text-sm font-medium">بدون أدوار</p>
                            <h3 class="text-3xl font-bold mt-2">@usersWithoutRoles</h3>
                        </div>
                        <div class="bg-white/20 rounded-full p-3">
                            <span class="material-icons-round text-4xl">person_off</span>
                        </div>
                    </div>
                </div>
            </section>
        }
    </main>
</div>

<script>
    document.getElementById('assignRolesForm')?.addEventListener('submit', function(e) {
        const saveBtn = document.getElementById('saveBtn');
        if (saveBtn) {
            saveBtn.disabled = true;
            saveBtn.innerHTML = '<span class="material-icons-round text-lg animate-spin">sync</span><span>جاري الحفظ...</span>';
        }
    });
</script>
