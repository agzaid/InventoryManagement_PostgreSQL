@model Application.Interfaces.Models.SysMangementIndexDto
@{
    ViewData["Title"] = "إدارة المستخدمين";
}

<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700&display=swap" rel="stylesheet" />
<link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet" />
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

<script>
    tailwind.config = {
        darkMode: "class",
        theme: {
            extend: {
                colors: {
                    primary: "#0ea5e9",
                    secondary: "#64748b",
                    accent: "#f59e0b",
                    "background-light": "#f8fafc",
                    "background-dark": "#0f172a",
                    "surface-light": "#ffffff",
                    "surface-dark": "#1e293b",
                    "border-light": "#e2e8f0",
                    "border-dark": "#334155",
                },
                fontFamily: {
                    sans: ["Cairo", "sans-serif"],
                    display: ["Cairo", "sans-serif"],
                },
            },
        },
    };
</script>

<div class="bg-background-light dark:bg-background-dark text-slate-800 dark:text-slate-200 font-sans min-h-screen flex flex-col transition-colors duration-300">
    <main class="flex-1 mx-auto w-full flex flex-col gap-6 p-6">
        
        @* Header Section *@
        <section class="bg-surface-light dark:bg-surface-dark p-6 rounded-xl border border-border-light dark:border-border-dark shadow-sm">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                <div>
                    <h2 class="text-2xl font-bold mb-2 flex items-center gap-2 text-slate-900 dark:text-white">
                        <span class="material-icons-round text-accent">manage_accounts</span>
                        إدارة المستخدمين
                    </h2>
                    <p class="text-sm text-slate-500 dark:text-slate-400">إدارة حسابات المستخدمين وصلاحياتهم في النظام</p>
                </div>
                <div class="flex gap-3">
                    <button onclick="openAddUserModal()" class="inline-flex items-center gap-2 px-4 py-2 bg-primary hover:bg-primary/90 text-white rounded-lg transition-colors shadow-sm">
                        <span class="material-icons-round text-lg">person_add</span>
                        <span class="font-medium">مستخدم جديد</span>
                    </button>
                  @*   <a href="@Url.Action("ManageRoles", "UserManagement")" class="inline-flex items-center gap-2 px-4 py-2 bg-accent hover:bg-accent/90 text-white rounded-lg transition-colors shadow-sm">
                        <span class="material-icons-round text-lg">shield</span>
                        <span class="font-medium">إدارة الأدوار</span>
                    </a>
                    <a href="@Url.Action("Index", "Permissions")" class="inline-flex items-center gap-2 px-4 py-2 bg-secondary hover:bg-secondary/90 text-white rounded-lg transition-colors shadow-sm">
                        <span class="material-icons-round text-lg">verified_user</span>
                        <span class="font-medium">الصلاحيات</span>
                    </a> *@
                </div>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="mt-4 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg flex items-center gap-3">
                    <span class="material-icons-round text-green-600 dark:text-green-400">check_circle</span>
                    <span class="text-green-800 dark:text-green-200">@TempData["Success"]</span>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="mt-4 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg flex items-center gap-3">
                    <span class="material-icons-round text-red-600 dark:text-red-400">error</span>
                    <span class="text-red-800 dark:text-red-200">@TempData["Error"]</span>
                </div>
            }
        </section>

        @* Statistics Cards *@
        <section class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl p-6 text-white shadow-lg">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-blue-100 text-sm font-medium mb-1">إجمالي المستخدمين</p>
                        <h3 class="text-3xl font-bold">@(Model.invUserDto?.Count ?? 0)</h3>
                    </div>
                    <div class="bg-white/20 rounded-full p-4">
                        <span class="material-icons-round text-4xl">people</span>
                    </div>
                </div>
            </div>

            <div class="bg-gradient-to-br from-green-500 to-green-600 rounded-xl p-6 text-white shadow-lg">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-green-100 text-sm font-medium mb-1">الموظفين المتاحين</p>
                        <h3 class="text-3xl font-bold">@(Model.EgxEmployeeDto?.Count ?? 0)</h3>
                    </div>
                    <div class="bg-white/20 rounded-full p-4">
                        <span class="material-icons-round text-4xl">badge</span>
                    </div>
                </div>
            </div>

            <div class="bg-gradient-to-br from-purple-500 to-purple-600 rounded-xl p-6 text-white shadow-lg">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-purple-100 text-sm font-medium mb-1">المستخدمين لهم صلاحيات</p>
                        <h3 class="text-3xl font-bold">@(Model.invUserDto?.Count ?? 0)</h3>
                    </div>
                    <div class="bg-white/20 rounded-full p-4">
                        <span class="material-icons-round text-4xl">verified</span>
                    </div>
                </div>
            </div>
        </section>

        @* Users Table *@
        <section class="bg-surface-light dark:bg-surface-dark rounded-xl border border-border-light dark:border-border-dark shadow-sm overflow-hidden">
            <div class="p-6 border-b border-border-light dark:border-border-dark">
                <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white flex items-center gap-2">
                        <span class="material-icons-round text-primary">list</span>
                        قائمة المستخدمين
                    </h3>
                    <div class="flex gap-3 w-full md:w-auto">
                        <div class="relative flex-1 md:w-64">
                            <span class="material-icons-round absolute right-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
                            <input type="text" id="searchInput" placeholder="بحث عن مستخدم..." 
                                   class="w-full pr-10 pl-4 py-2 bg-background-light dark:bg-background-dark border border-border-light dark:border-border-dark rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent text-slate-900 dark:text-white">
                        </div>
                    </div>
                </div>
            </div>

            <div class="overflow-x-auto">
                @if (Model.invUserDto != null && Model.invUserDto.Any())
                {
                    <table class="w-full" id="usersTable">
                        <thead class="bg-slate-50 dark:bg-slate-800 border-b border-border-light dark:border-border-dark">
                            <tr>
                                <th class="px-6 py-4 text-right text-xs font-semibold text-slate-600 dark:text-slate-300 uppercase tracking-wider">كود المستخدم</th>
                                <th class="px-6 py-4 text-right text-xs font-semibold text-slate-600 dark:text-slate-300 uppercase tracking-wider">اسم المستخدم</th>
                                <th class="px-6 py-4 text-right text-xs font-semibold text-slate-600 dark:text-slate-300 uppercase tracking-wider">الاسم الكامل</th>
                                <th class="px-6 py-4 text-right text-xs font-semibold text-slate-600 dark:text-slate-300 uppercase tracking-wider">الصلاحيات</th>
                                <th class="px-6 py-4 text-center text-xs font-semibold text-slate-600 dark:text-slate-300 uppercase tracking-wider">الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border-light dark:divide-border-dark">
                            @foreach (var user in Model.invUserDto)
                            {
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex items-center gap-2">
                                            <div class="bg-primary/10 rounded-full p-2">
                                                <span class="material-icons-round text-primary text-sm">tag</span>
                                            </div>
                                            <span class="text-sm font-medium text-slate-900 dark:text-white">@user.UserCode</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="text-sm text-slate-900 dark:text-white font-medium">@user.UserName</span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="text-sm text-slate-600 dark:text-slate-400">@user.FullNameArabic</span>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="flex flex-wrap gap-1">
                                            @{
                                                var permissions = new List<(string Code, string Name)>();
                                                if (!string.IsNullOrEmpty(user.Prog01)) permissions.Add(("PROG01", "وارد"));
                                                if (!string.IsNullOrEmpty(user.Prog02)) permissions.Add(("PROG02", "منصرف"));
                                                if (!string.IsNullOrEmpty(user.Prog03)) permissions.Add(("PROG03", "تحويل"));
                                                if (!string.IsNullOrEmpty(user.Prog13)) permissions.Add(("PROG13", "أرصدة"));
                                                if (!string.IsNullOrEmpty(user.Prog14)) permissions.Add(("PROG14", "رصيد حالي"));
                                                if (!string.IsNullOrEmpty(user.Prog33)) permissions.Add(("PROG33", "إدارة"));
                                            }
                                            @if (permissions.Any())
                                            {
                                                @foreach (var perm in permissions.Take(3))
                                                {
                                                    <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-200">
                                                        @perm.Name
                                                    </span>
                                                }
                                                @if (permissions.Count > 3)
                                                {
                                                    <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300">
                                                        +@(permissions.Count - 3)
                                                    </span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-xs text-slate-400">لا توجد صلاحيات</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-center">
                                        <div class="flex items-center justify-center gap-2">
                                            <button onclick="editUser(@user.UserCode)" 
                                                    class="inline-flex items-center gap-1 px-3 py-1.5 bg-blue-50 dark:bg-blue-900/20 hover:bg-blue-100 dark:hover:bg-blue-900/40 text-blue-600 dark:text-blue-400 rounded-lg transition-colors text-sm">
                                                <span class="material-icons-round text-sm">edit</span>
                                                <span>تعديل</span>
                                            </button>
                                            <button onclick="managePermissions(@user.UserCode, '@user.UserName')" 
                                                    class="inline-flex items-center gap-1 px-3 py-1.5 bg-purple-50 dark:bg-purple-900/20 hover:bg-purple-100 dark:hover:bg-purple-900/40 text-purple-600 dark:text-purple-400 rounded-lg transition-colors text-sm">
                                                <span class="material-icons-round text-sm">verified_user</span>
                                                <span>الصلاحيات</span>
                                            </button>
                                            <button onclick="deleteUser(@user.UserCode, '@user.UserName')" 
                                                    class="inline-flex items-center gap-1 px-3 py-1.5 bg-red-50 dark:bg-red-900/20 hover:bg-red-100 dark:hover:bg-red-900/40 text-red-600 dark:text-red-400 rounded-lg transition-colors text-sm">
                                                <span class="material-icons-round text-sm">delete</span>
                                                <span>حذف</span>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="p-12 text-center">
                        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-slate-100 dark:bg-slate-800 mb-4">
                            <span class="material-icons-round text-slate-400 text-4xl">people_outline</span>
                        </div>
                        <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-2">لا توجد مستخدمين</h3>
                        <p class="text-slate-500 dark:text-slate-400 mb-6">ابدأ بإضافة مستخدم جديد للنظام</p>
                        <button onclick="openAddUserModal()" class="inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primary/90 text-white rounded-lg transition-colors shadow-sm">
                            <span class="material-icons-round">person_add</span>
                            <span class="font-medium">إضافة مستخدم جديد</span>
                        </button>
                    </div>
                }
            </div>
        </section>

        @* Employees Reference Table *@
        @if (Model.EgxEmployeeDto != null && Model.EgxEmployeeDto.Any())
        {
            <section class="bg-surface-light dark:bg-surface-dark rounded-xl border border-border-light dark:border-border-dark shadow-sm overflow-hidden">
                <div class="p-6 border-b border-border-light dark:border-border-dark">
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white flex items-center gap-2">
                        <span class="material-icons-round text-accent">badge</span>
                        الموظفين المتاحين
                    </h3>
                    <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">قائمة الموظفين من نظام الموارد البشرية</p>
                </div>

                <div class="overflow-x-auto max-h-96">
                    <table class="w-full">
                        <thead class="bg-slate-50 dark:bg-slate-800 border-b border-border-light dark:border-border-dark sticky top-0">
                            <tr>
                                <th class="px-6 py-3 text-right text-xs font-semibold text-slate-600 dark:text-slate-300 uppercase tracking-wider">كود الموظف</th>
                                <th class="px-6 py-3 text-right text-xs font-semibold text-slate-600 dark:text-slate-300 uppercase tracking-wider">اسم الموظف</th>
                                <th class="px-6 py-3 text-right text-xs font-semibold text-slate-600 dark:text-slate-300 uppercase tracking-wider">كود القسم</th>
                                <th class="px-6 py-3 text-right text-xs font-semibold text-slate-600 dark:text-slate-300 uppercase tracking-wider">كود الفرع</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border-light dark:divide-border-dark">
                            @foreach (var emp in Model.EgxEmployeeDto)
                            {
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                                    <td class="px-6 py-3 whitespace-nowrap text-sm font-medium text-slate-900 dark:text-white">@emp.EmpCode</td>
                                    <td class="px-6 py-3 whitespace-nowrap text-sm text-slate-600 dark:text-slate-400">@emp.EmpName</td>
                                    <td class="px-6 py-3 whitespace-nowrap text-sm text-slate-600 dark:text-slate-400">@emp.DepCode</td>
                                    <td class="px-6 py-3 whitespace-nowrap text-sm text-slate-600 dark:text-slate-400">@emp.BranchCode</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }

    </main>
</div>

@* Add User Modal *@
<div id="addUserModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
    <div class="bg-surface-light dark:bg-surface-dark rounded-xl shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
        <div class="p-6 border-b border-border-light dark:border-border-dark">
            <div class="flex items-center justify-between">
                <h3 class="text-xl font-bold text-slate-900 dark:text-white flex items-center gap-2">
                    <span class="material-icons-round text-primary">person_add</span>
                    إضافة مستخدم جديد
                </h3>
                <button onclick="closeAddUserModal()" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200">
                    <span class="material-icons-round">close</span>
                </button>
            </div>
        </div>

        <form asp-action="CreateUser" method="post" class="p-6">
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                        <span class="material-icons-round text-sm align-middle">badge</span>
                        اختر الموظف
                    </label>
                    <select id="employeeSelect" name="UserCode" required class="w-full px-4 py-2 bg-background-light dark:bg-background-dark border border-border-light dark:border-border-dark rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent text-slate-900 dark:text-white" onchange="updateEmployeeName()">
                        <option value="">-- اختر موظف --</option>
                        @if (Model.EgxEmployeeDto != null)
                        {
                            @foreach (var emp in Model.EgxEmployeeDto)
                            {
                                <option value="@emp.EmpCode" data-name="@emp.EmpName">@emp.EmpName (@emp.EmpCode)</option>
                            }
                        }
                    </select>
                    <input type="hidden" id="fullNameArabic" name="FullNameArabic" value="">
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                        <span class="material-icons-round text-sm align-middle">person</span>
                        اسم المستخدم
                    </label>
                    <input type="text" name="UserName" required maxlength="10" 
                           class="w-full px-4 py-2 bg-background-light dark:bg-background-dark border border-border-light dark:border-border-dark rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent text-slate-900 dark:text-white"
                           placeholder="اسم المستخدم للدخول">
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                        <span class="material-icons-round text-sm align-middle">lock</span>
                        كلمة المرور
                    </label>
                    <input type="password" name="UserPasswd" required minlength="6" maxlength="16" 
                           class="w-full px-4 py-2 bg-background-light dark:bg-background-dark border border-border-light dark:border-border-dark rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent text-slate-900 dark:text-white"
                           placeholder="كلمة المرور (6-16 حرف)">
                </div>
            </div>

            <div class="flex gap-3 mt-6 pt-6 border-t border-border-light dark:border-border-dark">
                <button type="submit" class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3 bg-primary hover:bg-primary/90 text-white rounded-lg transition-colors shadow-sm font-medium">
                    <span class="material-icons-round">save</span>
                    <span>حفظ المستخدم</span>
                </button>
                <button type="button" onclick="closeAddUserModal()" class="px-6 py-3 bg-slate-200 dark:bg-slate-700 hover:bg-slate-300 dark:hover:bg-slate-600 text-slate-700 dark:text-slate-200 rounded-lg transition-colors font-medium">
                    إلغاء
                </button>
            </div>
        </form>
    </div>
</div>

@* Edit User Modal *@
<div id="editUserModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
    <div class="bg-surface-light dark:bg-surface-dark rounded-xl shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
        <div class="p-6 border-b border-border-light dark:border-border-dark">
            <div class="flex items-center justify-between">
                <h3 class="text-xl font-bold text-slate-900 dark:text-white flex items-center gap-2">
                    <span class="material-icons-round text-primary">edit</span>
                    تعديل المستخدم
                </h3>
                <button onclick="closeEditUserModal()" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200">
                    <span class="material-icons-round">close</span>
                </button>
            </div>
        </div>

        <form id="editUserForm" asp-action="EditUser" method="post" class="p-6">
            @Html.AntiForgeryToken()
            <input type="hidden" id="editUserId" name="Id" />
            <input type="hidden" id="editUserCode" name="UserCode" />
            <input type="hidden" id="editFullName" name="FullNameArabic" />
            
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                        <span class="material-icons-round text-sm align-middle">person</span>
                        اسم المستخدم
                    </label>
                    <input type="text" id="editUserName" name="UserName" required maxlength="10" 
                           class="w-full px-4 py-2 bg-background-light dark:bg-background-dark border border-border-light dark:border-border-dark rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent text-slate-900 dark:text-white">
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                        <span class="material-icons-round text-sm align-middle">badge</span>
                        الاسم الكامل
                    </label>
                    <input type="text" id="editUserFullName" readonly 
                           class="w-full px-4 py-2 bg-slate-100 dark:bg-slate-800 border border-border-light dark:border-border-dark rounded-lg text-slate-900 dark:text-white">
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                        <span class="material-icons-round text-sm align-middle">lock</span>
                        كلمة المرور الجديدة (اتركها فارغة للاحتفاظ بالحالية)
                    </label>
                    <input type="password" id="editUserPassword" name="UserPasswd" minlength="6" maxlength="16" 
                           class="w-full px-4 py-2 bg-background-light dark:bg-background-dark border border-border-light dark:border-border-dark rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent text-slate-900 dark:text-white"
                           placeholder="كلمة المرور الجديدة">
                </div>
            </div>

            <div class="flex gap-3 mt-6 pt-6 border-t border-border-light dark:border-border-dark">
                <button type="submit" class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3 bg-primary hover:bg-primary/90 text-white rounded-lg transition-colors shadow-sm font-medium">
                    <span class="material-icons-round">save</span>
                    <span>حفظ التعديلات</span>
                </button>
                <button type="button" onclick="closeEditUserModal()" class="px-6 py-3 bg-slate-200 dark:bg-slate-700 hover:bg-slate-300 dark:hover:bg-slate-600 text-slate-700 dark:text-slate-200 rounded-lg transition-colors font-medium">
                    إلغاء
                </button>
            </div>
        </form>
    </div>
</div>

@* Manage Permissions Modal *@
<div id="permissionsModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
    <div class="bg-surface-light dark:bg-surface-dark rounded-xl shadow-2xl max-w-4xl w-full max-h-[90vh] overflow-y-auto">
        <div class="p-6 border-b border-border-light dark:border-border-dark">
            <div class="flex items-center justify-between">
                <h3 class="text-xl font-bold text-slate-900 dark:text-white flex items-center gap-2">
                    <span class="material-icons-round text-primary">verified_user</span>
                    إدارة صلاحيات المستخدم: <span id="permUserName" class="text-accent"></span>
                </h3>
                <button onclick="closePermissionsModal()" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200">
                    <span class="material-icons-round">close</span>
                </button>
            </div>
        </div>

        <form id="permissionsForm" asp-action="ManageUserPermissions" method="post" class="p-6">
            @Html.AntiForgeryToken()
            <input type="hidden" id="permUserId" name="Id" />
            <input type="hidden" id="permUserCode" name="UserCode" />
            <input type="hidden" id="permUserNameField" name="UserName" />
            <input type="hidden" id="permFullName" name="FullNameArabic" />
            <input type="hidden" id="permUserPasswd" name="UserPasswd" />
            
            @* Role Selection Section *@
            <div class="mb-6 p-4 bg-gradient-to-r from-indigo-50 to-purple-50 dark:from-indigo-900/20 dark:to-purple-900/20 rounded-lg border border-indigo-200 dark:border-indigo-800">
                <h4 class="font-semibold text-slate-900 dark:text-white mb-3 flex items-center gap-2">
                    <span class="material-icons-round text-indigo-600 dark:text-indigo-400">shield</span>
                    اختيار دور (Role) - سيتم تطبيق جميع صلاحيات الدور المحدد
                </h4>
                <div id="rolesContainer" class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <!-- Roles will be loaded here dynamically -->
                </div>
            </div>

            <div class="border-t border-border-light dark:border-border-dark pt-4 mb-4">
                <h4 class="font-semibold text-slate-900 dark:text-white mb-3 flex items-center gap-2">
                    <span class="material-icons-round text-blue-600 dark:text-blue-400">tune</span>
                    أو اختر صلاحيات فردية
                </h4>
            </div>
            
            <div id="permissionsContainer" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <!-- Permissions will be loaded here dynamically -->
                <div class="col-span-full text-center py-8">
                    <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
                    <p class="text-sm text-slate-500 dark:text-slate-400 mt-2">جاري تحميل الصلاحيات...</p>
                </div>
            </div>

            <div class="flex gap-3 mt-6 pt-6 border-t border-border-light dark:border-border-dark">
                <button type="submit" class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-3 bg-primary hover:bg-primary/90 text-white rounded-lg transition-colors shadow-sm font-medium">
                    <span class="material-icons-round">save</span>
                    <span>حفظ الصلاحيات</span>
                </button>
                <button type="button" onclick="closePermissionsModal()" class="px-6 py-3 bg-slate-200 dark:bg-slate-700 hover:bg-slate-300 dark:hover:bg-slate-600 text-slate-700 dark:text-slate-200 rounded-lg transition-colors font-medium">
                    إلغاء
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    const users = @Html.Raw(Json.Serialize(Model.invUserDto ?? new List<Application.Interfaces.Models.InvUserDto>()));
    let availableRoles = [];
    let availablePermissions = [];

    // Module color mapping
    const moduleColors = {
        'الحركة اليومية': { bg: 'bg-blue-50 dark:bg-blue-900/20', icon: 'inventory_2', iconColor: 'text-blue-600 dark:text-blue-400' },
        'إدارة المخزون': { bg: 'bg-green-50 dark:bg-green-900/20', icon: 'warehouse', iconColor: 'text-green-600 dark:text-green-400' },
        'أكواد النظام': { bg: 'bg-purple-50 dark:bg-purple-900/20', icon: 'code', iconColor: 'text-purple-600 dark:text-purple-400' },
        'إدارة النظام': { bg: 'bg-amber-50 dark:bg-amber-900/20', icon: 'admin_panel_settings', iconColor: 'text-amber-600 dark:text-amber-400' },
        'المخزون': { bg: 'bg-green-50 dark:bg-green-900/20', icon: 'warehouse', iconColor: 'text-green-600 dark:text-green-400' },
        'الإدارة': { bg: 'bg-amber-50 dark:bg-amber-900/20', icon: 'admin_panel_settings', iconColor: 'text-amber-600 dark:text-amber-400' }
    };

    // Load roles on page load
    async function loadRoles() {
        try {
            const response = await fetch('@Url.Action("GetRolesWithPermissions", "UserManagement")');
            availableRoles = await response.json();
            console.log('Loaded roles:', availableRoles);
        } catch (error) {
            console.error('Error loading roles:', error);
        }
    }

    // Load permissions from database
    async function loadPermissions() {
        try {
            const response = await fetch('@Url.Action("GetAllPermissions", "UserManagement")');
            availablePermissions = await response.json();
            console.log('Loaded permissions:', availablePermissions);
            renderPermissions();
        } catch (error) {
            console.error('Error loading permissions:', error);
            document.getElementById('permissionsContainer').innerHTML = '<div class="col-span-full text-center py-8 text-red-600">حدث خطأ في تحميل الصلاحيات</div>';
        }
    }

    // Render permissions dynamically
    function renderPermissions() {
        const container = document.getElementById('permissionsContainer');
        if (!container || availablePermissions.length === 0) {
            container.innerHTML = '<div class="col-span-full text-center py-8 text-slate-500">لا توجد صلاحيات متاحة</div>';
            return;
        }

        container.innerHTML = availablePermissions.map(module => {
            const colors = moduleColors[module.module] || { bg: 'bg-slate-50 dark:bg-slate-900/20', icon: 'settings', iconColor: 'text-slate-600 dark:text-slate-400' };
            
            return `
                <div class="${colors.bg} p-4 rounded-lg">
                    <h4 class="font-semibold text-slate-900 dark:text-white mb-3 flex items-center gap-2">
                        <span class="material-icons-round ${colors.iconColor}">${colors.icon}</span>
                        ${module.module}
                    </h4>
                    <div class="space-y-2">
                        ${module.permissions.map(perm => `
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="checkbox" name="${perm.code}" value="1" class="rounded text-primary focus:ring-primary permission-checkbox">
                                <span class="text-sm text-slate-700 dark:text-slate-300">${perm.name}</span>
                            </label>
                        `).join('')}
                    </div>
                </div>
            `;
        }).join('');

        // Re-attach event listeners to new checkboxes
        attachPermissionCheckboxListeners();
    }

    function attachPermissionCheckboxListeners() {
        const permCheckboxes = document.querySelectorAll('.permission-checkbox');
        permCheckboxes.forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                clearRoleSelection();
            });
        });
    }

    // Call load functions when page loads
    document.addEventListener('DOMContentLoaded', function() {
        loadRoles();
        loadPermissions();
    });

    function openAddUserModal() {
        document.getElementById('addUserModal').classList.remove('hidden');
    }

    function closeAddUserModal() {
        document.getElementById('addUserModal').classList.add('hidden');
    }

    function editUser(userCode) {
        const user = users.find(u => u.userCode === userCode);
        if (!user) return;

        document.getElementById('editUserId').value = user.id;
        document.getElementById('editUserCode').value = user.userCode;
        document.getElementById('editUserName').value = user.userName;
        document.getElementById('editFullName').value = user.fullNameArabic;
        document.getElementById('editUserFullName').value = user.fullNameArabic;
        document.getElementById('editUserPassword').value = '';
        
        document.getElementById('editUserModal').classList.remove('hidden');
    }

    function closeEditUserModal() {
        document.getElementById('editUserModal').classList.add('hidden');
    }

    async function managePermissions(userCode, userName) {
        const user = users.find(u => u.userCode === userCode);
        if (!user) return;

        document.getElementById('permUserId').value = user.id;
        document.getElementById('permUserCode').value = user.userCode;
        document.getElementById('permUserNameField').value = user.userName;
        document.getElementById('permFullName').value = user.fullNameArabic;
        document.getElementById('permUserPasswd').value = user.userPasswd;
        document.getElementById('permUserName').textContent = userName;
        
        // Render roles
        renderRoles();
        
        // Ensure permissions are loaded
        if (availablePermissions.length === 0) {
            await loadPermissions();
        }
        
        // Wait a bit for DOM to update
        setTimeout(() => {
            // Check all permission checkboxes based on user's current permissions
            const allPermFields = ['Prog01', 'Prog02', 'Prog03', 'Prog11', 'Prog12', 'Prog13', 'Prog14', 'Prog21', 'Prog22', 'Prog23', 'Prog24', 'Prog25', 'Prog29', 'Prog31', 'Prog32', 'Prog33', 'Prog34', 'Prog35'];
            allPermFields.forEach(field => {
                const checkbox = document.querySelector(`input[name="${field}"]`);
                if (checkbox) {
                    checkbox.checked = user[field.toLowerCase()] === '1' || user[field.toLowerCase()] === 1;
                }
            });
        }, 100);
        
        document.getElementById('permissionsModal').classList.remove('hidden');
    }

    function renderRoles() {
        const container = document.getElementById('rolesContainer');
        if (!container) return;
        
        if (availableRoles.length === 0) {
            container.innerHTML = '<p class="text-sm text-slate-500 dark:text-slate-400">لا توجد أدوار متاحة</p>';
            return;
        }
        
        container.innerHTML = availableRoles.map(role => `
            <div class="bg-white dark:bg-slate-800 p-3 rounded-lg border border-slate-200 dark:border-slate-700 hover:border-indigo-400 dark:hover:border-indigo-600 transition-colors">
                <label class="flex items-start gap-3 cursor-pointer">
                    <input type="radio" name="selectedRole" value="${role.id}" 
                           class="mt-1 text-indigo-600 focus:ring-indigo-500"
                           onchange="applyRolePermissions('${role.id}')">
                    <div class="flex-1">
                        <div class="font-semibold text-slate-900 dark:text-white">${role.name}</div>
                        ${role.description ? `<div class="text-xs text-slate-500 dark:text-slate-400 mt-1">${role.description}</div>` : ''}
                        <div class="text-xs text-indigo-600 dark:text-indigo-400 mt-1">${role.permissions.length} صلاحية</div>
                    </div>
                </label>
            </div>
        `).join('');
    }

    function applyRolePermissions(roleId) {
        const role = availableRoles.find(r => r.id === roleId);
        if (!role) return;
        
        // First, uncheck all permissions
        const allPermFields = ['Prog01', 'Prog02', 'Prog03', 'Prog11', 'Prog12', 'Prog13', 'Prog14', 'Prog21', 'Prog22', 'Prog23', 'Prog24', 'Prog25', 'Prog29', 'Prog31', 'Prog32', 'Prog33', 'Prog34', 'Prog35'];
        allPermFields.forEach(field => {
            const checkbox = document.querySelector(`input[name="${field}"]`);
            if (checkbox) {
                checkbox.checked = false;
            }
        });
        
        // Then check permissions from the selected role
        role.permissions.forEach(permission => {
            const checkbox = document.querySelector(`input[name="${permission}"]`);
            if (checkbox) {
                checkbox.checked = true;
            }
        });
        
        console.log(`Applied ${role.permissions.length} permissions from role: ${role.name}`);
    }

    function clearRoleSelection() {
        const roleRadios = document.querySelectorAll('input[name="selectedRole"]');
        roleRadios.forEach(radio => radio.checked = false);
    }

    // Add event listeners to individual permission checkboxes to clear role selection
    document.addEventListener('DOMContentLoaded', function() {
        const permCheckboxes = document.querySelectorAll('#permissionsForm input[type="checkbox"]');
        permCheckboxes.forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                // When user manually changes a permission, clear role selection
                clearRoleSelection();
            });
        });
    });

    function closePermissionsModal() {
        document.getElementById('permissionsModal').classList.add('hidden');
    }

    function deleteUser(userCode, userName) {
        Swal.fire({
            title: 'هل أنت متأكد؟',
            html: `سيتم حذف المستخدم <strong>${userName}</strong> نهائياً`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#64748b',
            confirmButtonText: 'نعم، احذف',
            cancelButtonText: 'إلغاء',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '@Url.Action("DeleteUser", "UserManagement")/' + userCode;
                
                const token = document.querySelector('input[name="__RequestVerificationToken"]');
                if (token) {
                    const tokenInput = document.createElement('input');
                    tokenInput.type = 'hidden';
                    tokenInput.name = '__RequestVerificationToken';
                    tokenInput.value = token.value;
                    form.appendChild(tokenInput);
                }
                
                document.body.appendChild(form);
                form.submit();
            }
        });
    }

    document.getElementById('searchInput')?.addEventListener('input', function(e) {
        const searchTerm = e.target.value.toLowerCase();
        const rows = document.querySelectorAll('#usersTable tbody tr');
        
        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(searchTerm) ? '' : 'none';
        });
    });

    function updateEmployeeName() {
        const select = document.getElementById('employeeSelect');
        const hiddenInput = document.getElementById('fullNameArabic');
        
        if (select && hiddenInput) {
            const selectedOption = select.options[select.selectedIndex];
            const employeeName = selectedOption.getAttribute('data-name') || '';
            hiddenInput.value = employeeName;
        }
    }

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closeAddUserModal();
            closeEditUserModal();
            closePermissionsModal();
        }
    });
</script>
