@model IEnumerable<InventoryManagement.Models.UserManagement.UserListViewModel>
@{
    ViewData["Title"] = "إدارة المستخدمين";
}

<div class="container-fluid" dir="rtl">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fas fa-users"></i> إدارة المستخدمين
                    </h5>
                    <div>
                        <a href="@Url.Action("AssignRoles")" class="btn btn-light btn-sm">
                            <i class="fas fa-user-tag"></i> تعيين الأدوار
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>اسم المستخدم</th>
                                    <th>البريد الإلكتروني</th>
                                    <th>الاسم الكامل</th>
                                    <th>الكود الوظيفي</th>
                                    <th>الإدارة</th>
                                    <th>الحالة</th>
                                    <th>الأدوار</th>
                                    <th>تاريخ الإنشاء</th>
                                    <th>آخر تسجيل دخول</th>
                                    <th>الإجراءات</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model)
                                {
                                    <tr>
                                        <td>@user.UserName</td>
                                        <td>@user.Email</td>
                                        <td>@user.FullName</td>
                                        <td>@user.EmployeeCode</td>
                                        <td>@user.Department</td>
                                        <td>
                                            @if (user.IsActive)
                                            {
                                                <span class="badge bg-success">نشط</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">غير نشط</span>
                                            }
                                        </td>
                                        <td>
                                            @foreach (var role in user.Roles)
                                            {
                                                <span class="badge bg-info me-1">@role</span>
                                            }
                                        </td>
                                        <td>@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                                        <td>
                                            @(user.LastLoginAt?.ToString("yyyy-MM-dd HH:mm") ?? "لم يسجل بعد")
                                        </td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <a href="@Url.Action("Details", new { id = user.Id })" class="btn btn-sm btn-outline-primary" title="التفاصيل">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a href="@Url.Action("UserPermissions", new { userId = user.Id })" class="btn btn-sm btn-outline-info" title="الصلاحيات">
                                                    <i class="fas fa-key"></i>
                                                </a>
                                                <form asp-action="ToggleStatus" asp-route-id="@user.Id" method="post" style="display: inline;">
                                                    <button type="submit" class="btn btn-sm @(user.IsActive ? "btn-outline-warning" : "btn-outline-success")" 
                                                            title="@(user.IsActive ? "تعطيل" : "تفعيل")"
                                                            onclick="return confirm('هل أنت متأكد من @(user.IsActive ? "تعطيل" : "تفعيل") هذا المستخدم؟');">
                                                        <i class="fas @(user.IsActive ? "fa-ban" : "fa-check")"></i>
                                                    </button>
                                                </form>
                                                <form asp-action="Delete" asp-route-id="@user.Id" method="post" style="display: inline;">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="حذف"
                                                            onclick="return confirm('هل أنت متأكد من حذف هذا المستخدم؟');">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
