@model InventoryManagement.Models.UserManagement.ProfileViewModel
@{
    ViewData["Title"] = "الملف الشخصي";
}

<div class="container-fluid" dir="rtl">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fas fa-user"></i> الملف الشخصي
                    </h5>
                    <div>
                        <a href="@Url.Action("Edit")" class="btn btn-light btn-sm">
                            <i class="fas fa-edit"></i> تعديل
                        </a>
                        <a href="@Url.Action("ChangePassword")" class="btn btn-light btn-sm">
                            <i class="fas fa-key"></i> تغيير كلمة المرور
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <div class="row">
                        <div class="col-md-8">
                            <table class="table table-borderless">
                                <tr>
                                    <td><strong>اسم المستخدم:</strong></td>
                                    <td>@Model.UserName</td>
                                </tr>
                                <tr>
                                    <td><strong>البريد الإلكتروني:</strong></td>
                                    <td>@Model.Email</td>
                                </tr>
                                <tr>
                                    <td><strong>الاسم الكامل:</strong></td>
                                    <td>@Model.FullName</td>
                                </tr>
                                <tr>
                                    <td><strong>الكود الوظيفي:</strong></td>
                                    <td>@Model.EmployeeCode</td>
                                </tr>
                                <tr>
                                    <td><strong>الإدارة:</strong></td>
                                    <td>@Model.Department</td>
                                </tr>
                                <tr>
                                    <td><strong>رقم الهاتف:</strong></td>
                                    <td>@Model.PhoneNumber</td>
                                </tr>
                                <tr>
                                    <td><strong>الحالة:</strong></td>
                                    <td>
                                        @if (Model.IsActive)
                                        {
                                            <span class="badge bg-success">نشط</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">غير نشط</span>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>تاريخ الإنشاء:</strong></td>
                                    <td>@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                </tr>
                                <tr>
                                    <td><strong>آخر تسجيل دخول:</strong></td>
                                    <td>
                                        @(Model.LastLoginAt?.ToString("yyyy-MM-dd HH:mm") ?? "لم يسجل دخول بعد")
                                    </td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-header">
                                    <h6 class="mb-0">الأدوار المخصصة</h6>
                                </div>
                                <div class="card-body">
                                    @if (Model.Roles.Any())
                                    {
                                        @foreach (var role in Model.Roles)
                                        {
                                            <span class="badge bg-info me-1 mb-1">@role</span>
                                        }
                                    }
                                    else
                                    {
                                        <p class="text-muted">لا توجد أدوار مخصصة</p>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
